# apps/mobile — Expo client config. Copy to .env and fill in.
# Only EXPO_PUBLIC_* vars are readable by the app (Expo inlines them into
# the bundle). The native Cognito client is public, so none of these are
# secrets.

# Base URL of the FastAPI backend. On the iOS simulator, localhost reaches
# the host machine, so a locally-running API works as-is. For a physical
# device, use your Mac's LAN IP (e.g. http://192.168.1.20:8000).
EXPO_PUBLIC_API_URL=http://localhost:8000

# Cognito Hosted UI base domain (terraform output cognito_hosted_ui_domain).
EXPO_PUBLIC_COGNITO_DOMAIN=https://lawagent-divorse.auth.us-east-1.amazoncognito.com

# Native app client id (terraform output cognito_mobile_client_id). This id
# must also be in the API's COGNITO_EXTRA_AUDIENCES so its tokens are accepted.
EXPO_PUBLIC_COGNITO_CLIENT_ID=

# Custom URI scheme for the OAuth redirect. Must match app.config.ts `scheme`
# and the Cognito mobile client's callback URL (lawagent://callback).
EXPO_PUBLIC_SCHEME=lawagent

# Dev-only: skip the Cognito sign-in flow entirely and treat the user as a
# synthetic dev account. Pair with the API running LAWAGENT_AUTH_DISABLED=true.
# Never set true for a real build.
EXPO_PUBLIC_AUTH_DISABLED=false
