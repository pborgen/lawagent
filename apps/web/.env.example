# Copy to .env.local (gitignored). Used only by the Next.js dev server.

# Where the FastAPI backend lives. Local dev: 127.0.0.1:8000. Prod:
# the App Runner service URL printed by `terraform output app_runner_service_url`.
AGENT_API_URL=http://127.0.0.1:8000

# --- Cognito OIDC ---------------------------------------------------
# All five values come from `terraform output` in infra/terraform/.
#   cognito_user_pool_id      → COGNITO_USER_POOL_ID
#   cognito_client_id         → COGNITO_CLIENT_ID
#   cognito_client_secret     → COGNITO_CLIENT_SECRET  (sensitive)
#   cognito_hosted_ui_domain  → COGNITO_DOMAIN
#   (aws_region var)          → COGNITO_REGION
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=https://lawagent-divorse.auth.us-east-1.amazoncognito.com

# Must exactly match one of cognito_callback_urls / cognito_logout_urls
# in the Terraform stack. /auth/callback is the handler we serve.
COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
COGNITO_LOGOUT_REDIRECT_URI=http://localhost:3000

# Used to encrypt the session cookie. 32+ characters of entropy.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-openssl-rand-base64-48

# Dev escape hatch — when "true" the proxy stops gating routes and the
# /api/* proxies stop sending an Authorization header to FastAPI. Pair
# this with LAWAGENT_AUTH_DISABLED=true on the FastAPI side.
AUTH_DISABLED=false
