# All env-driven config is read through `packages/settings/`.
# Inline comments after a value (`KEY=val # comment`) work, but inline
# comments after an EMPTY value (`KEY= # comment`) leak into the value
# — keep comments on their own line for blank fields.

# --- Model profile ----------------------------------------------------
# A "profile" bundles a chat model with the embeddings model it must be
# paired with. Profiles are defined in config/profiles.yaml — add or edit
# them there. Pick one here; leave blank to use that file's `default:`.
#   local      HF Qwen2.5 + bge-small  — fully in-process, no API keys.
#                Run `uv sync --group local`; first use downloads ~6GB.
#   ollama     Ollama qwen2.5 + nomic-embed-text  — needs Ollama running
#                locally (brew install ollama) and the models pulled:
#                `ollama pull qwen2.5 && ollama pull nomic-embed-text`.
#   anthropic  Claude  + Voyage     — needs ANTHROPIC_API_KEY + VOYAGE_API_KEY
#   openai     GPT-4o  + OpenAI     — needs OPENAI_API_KEY
#   bedrock    Claude on Bedrock + Titan embeddings — needs AWS credentials
#                (env, ~/.aws/credentials, or instance role) with Bedrock
#                model access enabled in the account.
LAWAGENT_PROFILE=local

# --- API keys ---------------------------------------------------------
# Only needed when LAWAGENT_PROFILE selects a hosted profile.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# --- AWS / Bedrock ----------------------------------------------------
# Used by the `bedrock` profile. Standard AWS env vars; boto3 also reads
# ~/.aws/credentials and ~/.aws/config if these are unset. Per-profile
# region in config/profiles.yaml takes precedence over AWS_REGION.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

# --- Local model downloads --------------------------------------------
# Faster parallel downloads of the local profile's model weights.
# Needs the hf_transfer package (`uv sync --group local` installs it).
HF_HUB_ENABLE_HF_TRANSFER=1

# --- Vector store (pgvector on Postgres) ------------------------------
# Local dev: `docker compose up -d db` brings up Postgres + the pgvector
# extension at this URL. Point this at Aurora/RDS for AWS.
LAWAGENT_PG_URL=postgresql+psycopg://lawagent:lawagent@localhost:5432/lawagent

# --- CT eFile / eServices scraper -------------------------------------
# Used by `apps/efile`. Run: python -m efile.main pull
EFILE_USERNAME=
EFILE_PASSWORD=
EFILE_CRN=5124226
# Docket number (e.g. HHD-FA25-5089318-S). Used to prime LoadDocket.aspx
# before AttyCaseDetail. Required by `efile pull` and `pipeline run`.
EFILE_DOCKET_NO=

# --- S3 fetcher ------------------------------------------------------
# Used by `apps/s3fetch`. Run: python -m s3fetch.main pull
# Mirrors the prefix into data/case/s3/<id>/docs/.
# AWS credentials/region come from the standard AWS chain above.
LAWAGENT_S3_URI=
# Optional override for the directory under data/case/s3/.
# If unset, the last segment of the prefix (or the bucket name) is used.
LAWAGENT_S3_ID=

# Polite waits between navigations and downloads (seconds).
EFILE_MIN_WAIT_SECONDS=2
EFILE_MAX_WAIT_SECONDS=5
EFILE_DOWNLOAD_DELAY_SECONDS=1

# Where the login session is cached. Delete this file to force a fresh login.
EFILE_STORAGE_STATE=./data/case/efile/.storage_state.json
