# --- LLM (chat model) -------------------------------------------------
# All LLM construction is centralized in `packages/llm/chat.py`.
# Change the provider/model here and every app picks it up.

LAWAGENT_LLM_PROVIDER=anthropic              # anthropic | openai
LAWAGENT_LLM_MODEL=claude-opus-4-7           # leave blank to use the provider default
LAWAGENT_LLM_TEMPERATURE=0
LAWAGENT_LLM_MAX_TOKENS=4096

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Embeddings -------------------------------------------------------
LAWAGENT_EMBEDDINGS=voyage                   # voyage | openai
LAWAGENT_EMBEDDINGS_MODEL=                   # blank → provider default
VOYAGE_API_KEY=

# --- Vector store -----------------------------------------------------
LAWAGENT_VECTORSTORE_DIR=./data/vectorstore

# --- CT eFile / eServices scraper -------------------------------------
# Used by `apps/efile`. Run: python -m efile.main pull
EFILE_USERNAME=
EFILE_PASSWORD=
EFILE_CRN=5124226                            # case reference number to pull

# Polite-waits to avoid timeouts / rate limits. Each navigation sleeps
# a random duration between MIN and MAX seconds.
EFILE_MIN_WAIT_SECONDS=2
EFILE_MAX_WAIT_SECONDS=5
EFILE_DOWNLOAD_DELAY_SECONDS=1               # extra pause before each PDF download

# Where login session is cached. Delete this file to force a fresh login.
EFILE_STORAGE_STATE=./data/case/efile/.storage_state.json
