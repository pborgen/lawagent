# All env-driven config is read through `packages/settings/`.
# Inline comments after a value (`KEY=val # comment`) work, but inline
# comments after an EMPTY value (`KEY= # comment`) leak into the value
# — keep comments on their own line for blank fields.

# --- LLM (chat model) -------------------------------------------------
# LAWAGENT_LLM_PROVIDER: anthropic | openai
LAWAGENT_LLM_PROVIDER=anthropic
LAWAGENT_LLM_MODEL=claude-opus-4-7
LAWAGENT_LLM_TEMPERATURE=0
LAWAGENT_LLM_MAX_TOKENS=4096

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Embeddings -------------------------------------------------------
# LAWAGENT_EMBEDDINGS: voyage | openai
LAWAGENT_EMBEDDINGS=voyage
# Leave LAWAGENT_EMBEDDINGS_MODEL blank to use the provider default.
LAWAGENT_EMBEDDINGS_MODEL=
VOYAGE_API_KEY=

# --- Vector store (pgvector on Postgres) ------------------------------
# Local dev: `docker compose up -d db` brings up Postgres + the pgvector
# extension at this URL. Point this at Aurora/RDS for AWS.
LAWAGENT_PG_URL=postgresql+psycopg://lawagent:lawagent@localhost:5432/lawagent

# --- CT eFile / eServices scraper -------------------------------------
# Used by `apps/efile`. Run: python -m efile.main pull
EFILE_USERNAME=
EFILE_PASSWORD=
EFILE_CRN=5124226

# Polite waits between navigations and downloads (seconds).
EFILE_MIN_WAIT_SECONDS=2
EFILE_MAX_WAIT_SECONDS=5
EFILE_DOWNLOAD_DELAY_SECONDS=1

# Where the login session is cached. Delete this file to force a fresh login.
EFILE_STORAGE_STATE=./data/case/efile/.storage_state.json
