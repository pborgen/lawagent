# Copy to terraform.tfvars (gitignored) and fill in real values.

aws_region   = "us-east-1"
project_name = "lawagent-api"

github_owner = "pborgen"
github_repo  = "lawagent"

# If you already have a GitHub OIDC provider in this AWS account
# (only one is allowed), paste its ARN here. Otherwise leave empty
# and Terraform will create it.
github_oidc_provider_arn = ""

# S3 bucket holding case docs (granted to the App Runner instance role).
s3_bucket_name = "your-lawagent-bucket"

# Runtime env vars baked into the App Runner service.
lawagent_profile = "bedrock"
lawagent_s3_uri  = "s3://your-lawagent-bucket/case/"

# --- Database (RDS PostgreSQL + pgvector) ----------------------------
# The master password is generated, stored, and auto-rotated by RDS in
# AWS Secrets Manager — you never set or see it. The App Runner container
# fetches it at connect time. Everything below has a sane default
# (db.t4g.micro, Single-AZ, 20 GB gp3, db "lawagent").
# db_username          = "lawagent"
# db_name              = "lawagent"
# db_instance_class    = "db.t4g.micro"
# db_allocated_storage = 20
# db_engine_version    = "16.4"

# Initial data load: the DB is private by default, so your laptop can't
# reach it. To ingest from your machine, flip these on, `terraform
# apply`, load, then set both back and apply again.
# db_publicly_accessible = true
# admin_cidr             = "YOUR.IP.ADD.R/32"

# Image tag for the very first apply (App Runner needs *something* to pull).
# After CI starts pushing, leave this alone — the deploy workflow rolls
# out specific SHAs via apprunner:StartDeployment, and Terraform ignores
# image_identifier drift.
image_tag = "latest"

# --- Cognito (Google federation) -------------------------------------
# 1. In Google Cloud Console, create an OAuth 2.0 Web client.
# 2. `terraform apply` once with placeholder google_* values, grab the
#    `cognito_google_redirect_uri` output, paste it into Google as an
#    authorized redirect URI, then `apply` again with the real
#    google_client_id / google_client_secret.
cognito_domain_prefix = "lawagent-divorse"           # must be globally unique
google_client_id      = "REPLACE_ME.apps.googleusercontent.com"
google_client_secret  = "REPLACE_ME"

# Add prod origin(s) here once the Next.js app is deployed.
cognito_callback_urls = [
  "http://localhost:3000/auth/callback",
]
cognito_logout_urls = [
  "http://localhost:3000",
]

# Email allowlist enforced by the FastAPI backend even after Cognito auth.
cognito_allowed_emails = "pborgennc@gmail.com"
